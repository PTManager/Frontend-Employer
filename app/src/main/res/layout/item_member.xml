<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/MemberRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View style="@style/MemberAvatar" />

    <LinearLayout style="@style/MemberMeta">
        <TextView android:id="@+id/tv_name" style="@style/MemberName" android:text="" />
        <TextView android:id="@+id/tv_sub" style="@style/MemberSub" android:text="" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="내보내기"
        android:textColor="@color/accent_red"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
