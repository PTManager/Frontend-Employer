<?xml version="1.0" encoding="utf-8"?>
<!--
  홈 "소식" 카드: 공지 · 인수인계 · 대타요청 3행.
  직원 앱과 사장 앱이 동일 파일을 사용한다(두 res/layout 에 같은 내용).
  타입별 색상 아이콘 + 우측 상대 시각으로 구분.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:paddingHorizontal="14dp">

    <!-- 공지 -->
    <LinearLayout
        android:id="@+id/card_notice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:background="@drawable/bg_circle_notice"
            android:src="@drawable/ic_megaphone"
            android:tint="@color/cat_notice"
            android:contentDescription="공지" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_notice_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="공지를 불러오는 중…"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_notice_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text=""
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_notice_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="›"
            android:textColor="@color/text_hint"
            android:textSize="18sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- 인수인계 -->
    <LinearLayout
        android:id="@+id/card_handover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:background="@drawable/bg_circle_handover"
            android:src="@drawable/ic_person"
            android:tint="@color/cat_handover"
            android:contentDescription="인수인계" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_handover_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="불러오는 중…"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_handover_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text=""
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_handover_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="›"
            android:textColor="@color/text_hint"
            android:textSize="18sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- 대타요청 -->
    <LinearLayout
        android:id="@+id/card_swap_req"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:background="@drawable/bg_circle_swap"
            android:src="@drawable/ic_swap"
            android:tint="@color/cat_swap"
            android:contentDescription="대타요청" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_swap_req_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="불러오는 중…"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_swap_req_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text=""
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_swap_req_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="›"
            android:textColor="@color/text_hint"
            android:textSize="18sp" />
    </LinearLayout>
</LinearLayout>
