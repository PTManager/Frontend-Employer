<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="급여"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_month_selector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:text="12월 ▾"
                android:textColor="@color/brand"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:foreground="?attr/selectableItemBackground" />
        </LinearLayout>

        <!-- purple hero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:background="@drawable/bg_today_card"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이번 달 누적"
                android:textColor="@color/brand_border"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_month_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text=""
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_month_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text=""
                android:textColor="@color/brand_border"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 주차별 추이 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="주차별 추이"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:baselineAligned="false">

                <View android:id="@+id/bar_w1" style="@style/Bar" android:layout_height="6dp" />
                <View android:id="@+id/bar_w2" style="@style/Bar" android:layout_height="6dp" />
                <View android:id="@+id/bar_w3" style="@style/Bar" android:layout_height="6dp" />
                <View android:id="@+id/bar_w4" style="@style/Bar" android:layout_height="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <TextView android:id="@+id/tv_w1" style="@style/ChartDay" android:text="1주" />
                <TextView android:id="@+id/tv_w2" style="@style/ChartDay" android:text="2주" />
                <TextView android:id="@+id/tv_w3" style="@style/ChartDay" android:text="3주" />
                <TextView android:id="@+id/tv_w4" style="@style/ChartDay" android:text="4주" />
            </LinearLayout>
        </LinearLayout>

        <!-- 직원별 인건비 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="직원별 인건비"
            android:textColor="#444444"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/cost_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="14dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/tv_cost_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="18dp"
                android:gravity="center"
                android:text="집계된 인건비가 없습니다."
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
