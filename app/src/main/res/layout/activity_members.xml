<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/members_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="멤버 / 승인 관리"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <!-- pending join request -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="가입 승인 대기 1"
                android:textColor="@color/warn_orange"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/pending_join_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_warn"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="김알바"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="초대코드 A1B2C3 · 방금 신청"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_approve_join"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_primary"
                    android:text="승인"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="9dp"
                    android:foreground="?attr/selectableItemBackground" />
            </LinearLayout>

            <!-- member list -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="강남점 · 멤버 6명"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />

            <LinearLayout style="@style/MemberRow">
                <View style="@style/MemberAvatar" />
                <LinearLayout style="@style/MemberMeta">
                    <TextView style="@style/MemberName" android:text="박사장" />
                    <TextView style="@style/MemberSub" android:text="사장님 · 나" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/MemberRow">
                <View style="@style/MemberAvatar" />
                <LinearLayout style="@style/MemberMeta">
                    <TextView style="@style/MemberName" android:text="민지" />
                    <TextView style="@style/MemberSub" android:text="홀 · 알바" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/MemberRow">
                <View style="@style/MemberAvatar" />
                <LinearLayout style="@style/MemberMeta">
                    <TextView style="@style/MemberName" android:text="현우" />
                    <TextView style="@style/MemberSub" android:text="주방 · 알바" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/MemberRow">
                <View style="@style/MemberAvatar" />
                <LinearLayout style="@style/MemberMeta">
                    <TextView style="@style/MemberName" android:text="지수" />
                    <TextView style="@style/MemberSub" android:text="홀 · 알바" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/MemberRow">
                <View style="@style/MemberAvatar" />
                <LinearLayout style="@style/MemberMeta">
                    <TextView style="@style/MemberName" android:text="태윤" />
                    <TextView style="@style/MemberSub" android:text="주방 · 알바" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/MemberRow">
                <View style="@style/MemberAvatar" />
                <LinearLayout style="@style/MemberMeta">
                    <TextView style="@style/MemberName" android:text="서연" />
                    <TextView style="@style/MemberSub" android:text="홀 · 알바" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
