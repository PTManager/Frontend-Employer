<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="스케줄 편성"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025년 12월 ▾"
                android:textColor="@color/brand"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- week strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="월" />
                <TextView style="@style/DayNum" android:text="1" />
            </LinearLayout>
            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="화" />
                <TextView style="@style/DayNum" android:text="2" />
            </LinearLayout>
            <LinearLayout style="@style/DayCell" android:background="@drawable/bg_day_selected">
                <TextView style="@style/DayLabel" android:text="수" android:textColor="#CFE0FF" />
                <TextView style="@style/DayNum" android:text="3" android:textColor="@color/white" />
            </LinearLayout>
            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="목" />
                <TextView style="@style/DayNum" android:text="4" />
            </LinearLayout>
            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="금" />
                <TextView style="@style/DayNum" android:text="5" />
            </LinearLayout>
            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="토" android:textColor="@color/weekend_red" />
                <TextView style="@style/DayNum" android:text="6" />
            </LinearLayout>
            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="일" android:textColor="@color/weekend_red" />
                <TextView style="@style/DayNum" android:text="7" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="12월 3일 수요일 · 근무 3타임"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- shift 1 오픈 -->
        <LinearLayout style="@style/ShiftRow" android:background="@drawable/bg_schedule_active">
            <TextView style="@style/ShiftTime" android:text="09:00 – 14:00 · 오픈" />
            <LinearLayout style="@style/ShiftChips">
                <TextView style="@style/WorkerChip" android:text="현우" />
            </LinearLayout>
        </LinearLayout>

        <!-- shift 2 홀 -->
        <LinearLayout style="@style/ShiftRow" android:background="@drawable/bg_schedule_active">
            <TextView style="@style/ShiftTime" android:text="14:00 – 18:00 · 홀" />
            <LinearLayout style="@style/ShiftChips">
                <TextView style="@style/WorkerChip" android:text="민지" />
                <TextView style="@style/WorkerChip" android:text="현우" />
            </LinearLayout>
        </LinearLayout>

        <!-- shift 3 마감 (미배정) -->
        <LinearLayout style="@style/ShiftRow" android:background="@drawable/bg_schedule_muted">
            <TextView style="@style/ShiftTime" android:text="18:00 – 22:00 · 마감"
                android:textColor="#555555" />
            <LinearLayout style="@style/ShiftChips">
                <TextView style="@style/WorkerChipEmpty" android:text="+ 배정 필요" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btn_add_shift"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_dashed"
            android:text="+ 시프트 추가"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="13dp"
            android:foreground="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btn_attendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_btn_outline_gray"
            android:text="근무별 출근 현황 보기"
            android:textColor="@color/brand"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:foreground="?attr/selectableItemBackground" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
