<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- left accent bar -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/brand" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- body inset to reveal a 4dp accent strip on the left -->
    <item android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_bg" />
            <corners android:topRightRadius="14dp" android:bottomRightRadius="14dp" />
        </shape>
    </item>
</layer-list>
